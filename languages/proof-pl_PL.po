msgid "2 hours ago"
msgstr ""

#: src/Admin/Settings.php:224
msgid "Enabled"
msgstr "Włączone"

#: src/Service/FrontendService.php:87
msgid "Recent purchase"
msgstr "Niedawny zakup"

#: src/Service/FrontendService.php:88
msgid "Dismiss notification"
msgstr "Zamknij powiadomienie"

#. translators: connects a name to a city, e.g. "Alex from Berlin".
#: src/Service/FrontendService.php:90
msgid "from"
msgstr "z"

#. translators: connects a buyer to a product, e.g. "bought Hoodie".
#: src/Service/FrontendService.php:92
msgid "bought"
msgstr "kupił(a)"

#: src/Service/OrderFeed.php:124
msgid "Someone"
msgstr "Ktoś"

#. translators: %s: human-readable time difference, e.g. "2 hours".
#: src/Service/OrderFeed.php:171
#, php-format
msgid "%s ago"
msgstr "%s temu"

